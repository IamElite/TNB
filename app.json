{
    "name": "Anime Bypass Bot",
    "description": "Telegram bot for bypassing, downloading and uploading anime",
    "repository": "https://github.com/IamElite/TNB",
    "env": {
        "UPSTREAM_REPO": {
            "description": "Upstream Repository URL",
            "value": "https://github.com/IamElite/TNB",
            "required": false
        },
        "UPSTREAM_BRANCH": {
            "description": "Upstream Repository Branch",
            "value": "sb1",
            "required": false
        }
